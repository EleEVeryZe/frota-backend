{
	"name": "my-app",
	"version": "1.0.0",
	"description": "Production-ready Express TypeScript application",
	"main": "dist/server.js",
	"type": "commonjs",
	"scripts": {
		"dev": "tsx watch src/infra/adapters/rest_api/server.ts",
		"build": "tsc && tsc-alias ",
		"start": "node --enable-source-maps dist/server.js",
		"lint": "eslint src --ext .ts --fix",
		"format": "prettier --write \"src/**/*.ts\"",
		"clean": "rimraf dist",
		"test": "jest",
		"test:watch": "jest --watch --verbose=false --runInBand",
		"test:cov": "jest --coverage",
		"test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
		"test:e2e": "jest --config ./test/jest-e2e.json --verbose=false"
	},
	"keywords": [
		"express",
		"typescript",
		"api"
	],
	"author": "",
	"license": "ISC",
	"dependencies": {
		"compression": "^1.8.1",
		"cors": "^2.8.5",
		"dotenv": "^17.2.3",
		"express": "^5.1.0",
		"express-rate-limit": "^8.2.1",
		"helmet": "^8.1.0",
		"morgan": "^1.10.1",
		"pino": "^10.1.0",
		"pino-pretty": "^13.1.2",
		"redis": "^5.11.0"
	},
	"devDependencies": {
		"@eslint/js": "^9.39.1",
		"@types/compression": "^1.8.1",
		"@types/cors": "^2.8.19",
		"@types/express": "^5.0.5",
		"@types/jest": "^30.0.0",
		"@types/morgan": "^1.9.10",
		"@types/node": "^24.10.0",
		"@types/supertest": "^7.2.0",
		"@typescript-eslint/eslint-plugin": "^8.46.3",
		"@typescript-eslint/parser": "^8.46.3",
		"eslint": "^9.39.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.4",
		"jest": "^30.3.0",
		"prettier": "^3.6.2",
		"supertest": "^7.2.2",
		"ts-jest": "^29.4.6",
		"tsc-alias": "^1.8.16",
		"tsconfig-paths": "^4.2.0",
		"tsx": "^4.20.6",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.46.3"
	}
}
